PORT=4000
JWT_SECRET=change-this-to-a-long-random-string

# Get this from Render: New -> PostgreSQL (free tier) -> Internal Database URL
# Local dev example: postgres://postgres:postgres@localhost:5432/tracker
DATABASE_URL=postgres://user:password@host:5432/tracker

# How stale a ping has to be before a device is considered offline (minutes)
OFFLINE_THRESHOLD_MINUTES=30

# Battery percentage that triggers a low-battery alert
LOW_BATTERY_THRESHOLD=20
